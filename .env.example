# Copy this file to .env and fill in your values
# Never commit .env — only .env.example goes to GitHub

# --- AI APIs ---
ANTHROPIC_API_KEY=                  # claude.ai → API Keys
OPENAI_API_KEY=                     # platform.openai.com → API Keys (optional)
MANUS_API_KEY=                      # manus.im → Settings → API

# --- Google (OAuth) ---
# Run: python execution/google_auth_setup.py to generate token.json
AUTOMATION_CONFIG_SHEET_ID=         # Google Sheet ID for main config/tracker
TECH_RADAR_TRACKER_SHEET_ID=        # Tech radar tracker sheet ID
LEAD_ANALYTICS_SHEET_ID=            # Lead analytics sheet ID

# --- Airtable ---
AIRTABLE_API_KEY=                   # airtable.com → Account → API
AIRTABLE_BASE_ID=                   # Your base ID (appXXXXXXXXX)
AIRTABLE_LEADS_ID=                  # Leads table ID
AIRTABLE_UPWORK_ID=                 # Upwork Jobs table ID

# --- Telegram Bots ---
TELEGRAM_BOT_TOKEN=                 # Tech Radar bot (@BotFather)
TELEGRAM_CHAT_ID=                   # Tech Radar chat ID
INVESTMENT_BOT_TOKEN=               # Investment Research bot
INVESTMENT_CHAT_ID=                 # Investment Research chat ID
LEAD_ANALYTICS_BOT_TOKEN=           # Lead Analytics bot
LEAD_ANALYTICS_CHAT_ID=             # Lead Analytics chat ID

# --- Microsoft (Outlook drafts) ---
MICROSOFT_TENANT_ID=                # Azure AD → App Registration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=             # e.g. support@yourcompany.com

# --- Data / Enrichment ---
APIFY_API_TOKEN=                    # apify.com → Settings → Integrations
ANYMAILFINDER_API_KEY=              # anymailfinder.com → API (optional fallback)

# --- Slack ---
SLACK_WEBHOOK_URL=                  # Slack app → Incoming Webhooks
